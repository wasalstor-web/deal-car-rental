# نسخ إلى `.env` في مجلد mobile (الملف `.env` مُستبعد من git).
# ربط تطبيق Android بنفس الـ API الذي يشغّله Docker على الجهاز (منفذ 4002).
#
# محاكي Android (AVD): 10.0.2.2 = عنوان جهازك (الـ host) من داخل المحاكي.
# جهاز حقيقي على نفس الـ Wi‑Fi: استبدل 10.0.2.2 بعنوان IPv4 للكمبيوتر (مثلاً من ipconfig).
#
# يجب أن تتطابق مسارات CDN مع نفس الـ host والمنفذ مثل BC_API_HOST.

BC_API_HOST=http://10.0.2.2:4002
BC_DEFAULT_LANGUAGE=en
BC_PAGE_SIZE=20
BC_CARS_PAGE_SIZE=8
BC_BOOKINGS_PAGE_SIZE=8
BC_CDN_USERS=http://10.0.2.2:4002/cdn/bookcars/users
BC_CDN_CARS=http://10.0.2.2:4002/cdn/bookcars/cars
BC_CDN_LICENSES=http://10.0.2.2:4002/cdn/bookcars/licenses
BC_CDN_TEMP_LICENSES=http://10.0.2.2:4002/cdn/bookcars/temp/licenses
BC_SUPPLIER_IMAGE_WIDTH=60
BC_SUPPLIER_IMAGE_HEIGHT=30
BC_CAR_IMAGE_WIDTH=300
BC_CAR_IMAGE_HEIGHT=200
BC_MINIMUM_AGE=21
BC_STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY
BC_STRIPE_MERCHANT_IDENTIFIER=MERCHANT_IDENTIFIER
BC_STRIPE_COUNTRY_CODE=US
BC_BASE_CURRENCY=USD
BC_DEPOSIT_FILTER_VALUE_1=250
BC_DEPOSIT_FILTER_VALUE_2=500
BC_DEPOSIT_FILTER_VALUE_3=750
BC_WEBSITE_NAME=BookCars
BC_GOOGLE_WEB_CLIENT_ID=GOOGLE_WEB_CLIENT_ID

# Self-hosted Supabase — emulator: 10.0.2.2 + نفس منفذ KONG_HTTP_PORT على الـ host (مثال 8000 أو 8010). طابق ANON_KEY مع supabase/docker/.env
BC_SUPABASE_URL=http://10.0.2.2:8010
