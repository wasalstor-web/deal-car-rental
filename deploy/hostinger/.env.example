# Copy to deploy/hostinger/.env (do not commit .env).
# FQDNs must match DNS A/AAAA records pointing at your VPS (e.g. 147.93.120.99).

COMPOSE_PROJECT_NAME=dealcar

# Traefik on this VPS uses Host(`…`) + Let’s Encrypt (see traefik project).
WEB_FQDN=dealcar-web.srv1125123.hstgr.cloud
API_FQDN=dealcar-api.srv1125123.hstgr.cloud
ADMIN_FQDN=dealcar-admin.srv1125123.hstgr.cloud

# Cookie domain: leading dot allows api/web/admin subdomains to share session cookies.
COOKIE_DOMAIN=.srv1125123.hstgr.cloud

# Mongo (must match secrets/backend.env if you set BC_DB_URI there — compose overrides BC_DB_URI by default)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional: Supabase cloud (or public Kong URL) baked into frontend at build time
SUPABASE_PUBLIC_URL=
SUPABASE_ANON_KEY=
