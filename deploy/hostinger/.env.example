# Copy to deploy/hostinger/.env (do not commit .env).
# FQDNs must match DNS A/AAAA records pointing at your VPS (e.g. 147.93.120.99).
#
# Use a unique COMPOSE_PROJECT_NAME on this VPS so Traefik router names and container prefixes
# never clash with wordpress-o8cs, n8n-btzq, or other stacks (letters, digits, hyphen, underscore).

COMPOSE_PROJECT_NAME=dealcarbk

# Traefik on this VPS uses Host(`…`) + Let’s Encrypt (see traefik project).
WEB_FQDN=dealcar-web.srv1125123.hstgr.cloud
API_FQDN=dealcar-api.srv1125123.hstgr.cloud
ADMIN_FQDN=dealcar-admin.srv1125123.hstgr.cloud

# Cookie domain: leading dot allows api/web/admin subdomains to share session cookies.
COOKIE_DOMAIN=.srv1125123.hstgr.cloud

# Mongo (must match secrets/backend.env if you set BC_DB_URI there — compose overrides BC_DB_URI by default)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Supabase: إما سحابي (*.supabase.co) أو نفس الـ VPS (Kong للـ Docker الذاتي)
# SUPABASE_PUBLIC_URL يجب أن يطابق SUPABASE_PUBLIC_URL في .env لمجلد supabase/docker (HTTPS عبر Traefik إن وُجد)
# SUPABASE_ANON_KEY = قيمة ANON_KEY من ذلك الملف
SUPABASE_PUBLIC_URL=
SUPABASE_ANON_KEY=

# --- مكدس موحّد + Traefik (npm run docker:up:hostinger) ---
SUPABASE_FQDN=dealcar-supabase.srv1125123.hstgr.cloud
TRAEFIK_DOCKER_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt
