# Optional: copy to repo root as `.env` when using the **root** docker-compose.yml on a VPS
# that already uses default ports (4002, 3001, 13080, …) for another app.
# Does not apply to deploy/hostinger/docker-compose.yml (Traefik — no host ports).

BOOKCARS_HOST_PORT_MONGO=37018
BOOKCARS_HOST_PORT_MONGO_EXPRESS=18084
BOOKCARS_HOST_PORT_API=34002
BOOKCARS_HOST_PORT_ADMIN=23001
BOOKCARS_HOST_PORT_WEB=23080
BOOKCARS_HOST_PORT_WEB_HTTPS=23443
