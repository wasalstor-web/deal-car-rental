{
  "name": "bookcars",
  "version": "8.8.0",
  "description": "Deal Car Rental — ديل لتأجير السيارات (BookCars-based car rental platform)",
  "keywords": [
    "react",
    "react-native",
    "mongodb",
    "stripe",
    "paypal",
    "car-rental",
    "car-rental-system",
    "aggregator",
    "bookcars"
  ],
  "homepage": "https://github.com/wasalstor-web/deal-car-rental#readme",
  "bugs": {
    "url": "https://github.com/wasalstor-web/deal-car-rental/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wasalstor-web/deal-car-rental.git"
  },
  "funding": "https://github.com/sponsors/aelassas",
  "author": "Akram El Assas",
  "license": "MIT",
  "type": "module",
  "main": "pre-commit.js",
  "scripts": {
    "pre-commit": "node pre-commit.js",
    "releases": "node releases.js",
    "prepare": "husky install",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "i18n:export": "node __scripts/i18n/export-en.mjs",
    "i18n:bootstrap-ar": "node __scripts/i18n/bootstrap-ar.mjs",
    "i18n:apply-ar": "node __scripts/i18n/apply-ar.mjs",
    "i18n:fetch-ar": "node __scripts/i18n/fetch-ar-translations.mjs",
    "i18n:verify": "node __scripts/i18n/verify-locale-parity.mjs",
    "i18n:verify-mobile": "node __scripts/i18n/verify-mobile-lang-parity.mjs",
    "i18n:export-mobile": "node __scripts/i18n/export-mobile-en.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:up:tools": "docker compose --profile devtools up -d --build",
    "mobile:android": "npm run android --prefix mobile",
    "supabase:merge-gotrue": "node __scripts/supabase/merge-gotrue-bookcars.mjs",
    "supabase:merge-gotrue:fix-lf": "node __scripts/supabase/merge-gotrue-bookcars.mjs --fix-kong-lf",
    "supabase:sync-bookcars": "node __scripts/supabase/sync-bookcars-from-supabase.mjs",
    "supabase:verify-local": "node __scripts/supabase/verify-supabase-local.mjs",
    "supabase:seed-user": "node __scripts/supabase/seed-local-auth-user.mjs",
    "supabase:apply-docker": "node __scripts/supabase/apply-supabase-to-docker.mjs"
  },
  "devDependencies": {
    "chalk": "^5.4.1",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "p-limit": "^6.2.0"
  }
}
