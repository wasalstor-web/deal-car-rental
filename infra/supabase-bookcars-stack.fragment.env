# يدمجها merge-gotrue-bookcars.mjs في supabase/docker/.env — منافذ لا تتعارض مع docker-compose.yml لـ BookCars
# (Mongo 27018، الويب 13080، API 4002، الأدمن 3001، HTTPS واجهة 8443)
KONG_HTTP_PORT=8010
KONG_HTTPS_PORT=8450
SUPABASE_PUBLIC_URL=http://localhost:8010
API_EXTERNAL_URL=http://localhost:8010
POSTGRES_PORT=54332
POOLER_PROXY_PORT_TRANSACTION=65432
ENABLE_EMAIL_AUTOCONFIRM=true
