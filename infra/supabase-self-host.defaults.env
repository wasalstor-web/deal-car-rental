# Reference only — Supabase official docker/.env.example (legacy HS256) + BookCars local Docker ports.
# 1) npm run supabase:merge-gotrue  (أو انسخ infra/supabase-gotrue-bookcars.fragment.env) → SITE_URL / ADDITIONAL_REDIRECT_URLS
# 2) npm run supabase:sync-bookcars  ← يزامن JWT + ANON + عنوان Kong إلى backend/frontend/mobile من supabase/docker/.env
# 3) يدويًا إن لم تستخدم السكربت: backend/.env.docker → BC_SUPABASE_JWT_SECRET = JWT_SECRET
# 4) frontend/.env.docker → VITE_BC_SUPABASE_URL + VITE_BC_SUPABASE_ANON_KEY (= SUPABASE_PUBLIC_URL + ANON_KEY)
# 5) mobile/.env → BC_SUPABASE_URL (محاكي: 10.0.2.2 + منفذ Kong) + BC_SUPABASE_ANON_KEY
# تطوير محلي بدون SMTP: في supabase/docker/.env ضع ENABLE_EMAIL_AUTOCONFIRM=true
# من جذر bookcars: npm run supabase:verify-local | supabase:seed-user | supabase:apply-docker (بعد تعديل supabase/.env)
# Studio: افتح SUPABASE_PUBLIC_URL في المتصفح + Basic Auth (DASHBOARD_* في supabase/.env)
#
# تعارض المنافذ (مثال شائع على Windows):
#   POSTGRES_PORT=54330
#   KONG_HTTP_PORT=8010
#   KONG_HTTPS_PORT=8450
#   SUPABASE_PUBLIC_URL=http://localhost:8010
#   API_EXTERNAL_URL=http://localhost:8010
# ثم أعد: docker compose up -d --force-recreate kong  إن لزم لنشر المنافذ على المضيف.

JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:13080
